{
	"name": "sound-bot",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "nest build && yarn copy-assets",
		"format": "biome format --write .",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "biome check --write .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "jest --passWithNoTests",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"copy-assets": "cpx \"src/assets/**/*\" dist/assets",
		"prepare": "husky"
	},
	"dependencies": {
		"@discord-player/extractor": "^7.1.0",
		"@discordjs/voice": "^0.18.0",
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.0.0",
		"@nestjs/core": "^10.0.0",
		"@nestjs/platform-express": "^11.1.13",
		"discord-player": "^7.1.0",
		"discord-player-soundcloud": "^1.0.7",
		"discord-player-spotify": "https://github.com/hmes98318/discord-player-spotify#master",
		"discord.js": "^14.25.1",
		"ejs": "^4.0.1",
		"ffmpeg-static": "^5.3.0",
		"glob": "^13.0.1",
		"libsodium-wrappers": "^0.7.11",
		"mediaplex": "^1.0.0",
		"opusscript": "^0.1.1",
		"play-dl": "^1.9.7",
		"reflect-metadata": "^0.1.13",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@nestjs/cli": "^10.0.0",
		"@nestjs/schematics": "^10.0.0",
		"@nestjs/testing": "^10.0.0",
		"@types/express": "^4.17.17",
		"@types/glob": "^9.0.0",
		"@types/jest": "^29.5.2",
		"@types/node": "^22.0.0",
		"@types/supertest": "^2.0.12",
		"cpx": "^1.5.0",
		"husky": "^9.1.7",
		"jest": "^29.5.0",
		"lint-staged": "^16.3.3",
		"source-map-support": "^0.5.21",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.0",
		"ts-loader": "^9.4.3",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.1.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@core/(.*)$": "<rootDir>/core/$1"
		}
	}
}
