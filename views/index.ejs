<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sound Bot - Discord Music Bot</title>
  <meta name="description" content="A powerful Discord music bot that plays music from Spotify and SoundCloud. Add it to your server today!">
  <meta name="theme-color" content="#5865F2">
  
  <!-- Open Graph -->
  <meta property="og:title" content="Sound Bot - Discord Music Bot">
  <meta property="og:description" content="A powerful Discord music bot that plays music from Spotify and SoundCloud.">
  <meta property="og:type" content="website">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --discord-blurple: #5865F2;
      --discord-green: #57F287;
      --discord-dark: #23272A;
      --discord-darker: #1a1d21;
      --spotify-green: #1DB954;
      --soundcloud-orange: #FF5500;
      --text-primary: #ffffff;
      --text-secondary: #b9bbbe;
      --card-bg: #2f3136;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: linear-gradient(135deg, var(--discord-darker) 0%, var(--discord-dark) 100%);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* Navigation */
    nav {
      padding: 20px 0;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(26, 29, 33, 0.9);
      backdrop-filter: blur(10px);
      z-index: 100;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    nav .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      font-size: 1.5rem;
    }

    .logo-icon {
      width: 40px;
      height: 40px;
      background: var(--discord-blurple);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--text-primary);
    }

    /* Hero Section */
    .hero {
      padding: 160px 0 100px;
      text-align: center;
    }

    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      margin-bottom: 24px;
      background: linear-gradient(135deg, var(--text-primary), var(--discord-blurple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 40px;
    }

    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      background: var(--discord-blurple);
      color: white;
      box-shadow: 0 4px 20px rgba(88, 101, 242, 0.4);
    }

    .btn-primary:hover {
      box-shadow: 0 6px 30px rgba(88, 101, 242, 0.5);
    }

    .btn-secondary {
      background: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Features Section */
    .features {
      padding: 80px 0;
    }

    .section-title {
      text-align: center;
      margin-bottom: 60px;
    }

    .section-title h2 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .section-title p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }

    .feature-card {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 32px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      transition: transform 0.2s, border-color 0.2s;
    }

    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .feature-icon {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    .feature-icon.spotify {
      background: rgba(29, 185, 84, 0.15);
      color: var(--spotify-green);
    }

    .feature-icon.soundcloud {
      background: rgba(255, 85, 0, 0.15);
      color: var(--soundcloud-orange);
    }

    .feature-icon.commands {
      background: rgba(88, 101, 242, 0.15);
      color: var(--discord-blurple);
    }

    .feature-icon.quality {
      background: rgba(87, 242, 135, 0.15);
      color: var(--discord-green);
    }

    .feature-card h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .feature-card p {
      color: var(--text-secondary);
    }

    /* Commands Section */
    .commands-section {
      padding: 80px 0;
    }

    .commands-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      max-width: 900px;
      margin: 0 auto;
    }

    @media (max-width: 600px) {
      .commands-list {
        grid-template-columns: 1fr;
      }
    }

    .command {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 20px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .command-name {
      font-family: 'SF Mono', 'Fira Code', monospace;
      background: rgba(88, 101, 242, 0.15);
      color: var(--discord-blurple);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
      white-space: nowrap;
    }

    .command-desc {
      color: var(--text-secondary);
      font-size: 0.95rem;
      white-space: nowrap;
    }

    /* CTA Section */
    .cta {
      padding: 100px 0;
      text-align: center;
    }

    .cta-box {
      background: linear-gradient(135deg, var(--discord-blurple), #7289da);
      border-radius: 24px;
      padding: 60px 40px;
      max-width: 800px;
      margin: 0 auto;
    }

    .cta-box h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .cta-box p {
      font-size: 1.1rem;
      opacity: 0.9;
      margin-bottom: 32px;
    }

    .cta-box .btn-primary {
      background: white;
      color: var(--discord-blurple);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    /* Footer */
    footer {
      padding: 40px 0;
      text-align: center;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    footer p {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    footer a {
      color: var(--discord-blurple);
      text-decoration: none;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }

      .hero {
        padding: 120px 0 60px;
      }

      .cta-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn {
        width: 100%;
        max-width: 300px;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <nav>
    <div class="container">
      <div class="logo">
        <div class="logo-icon">🎵</div>
        <span>Sound Bot</span>
      </div>
      <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#commands">Commands</a></li>
        <li><a href="https://github.com/aeonamind/sound-bot" target="_blank">GitHub</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <section class="hero">
      <div class="container">
        <h1>Your Server's DJ</h1>
        <p>A powerful Discord music bot that brings the party to your server. Play music from Spotify and SoundCloud with simple commands.</p>
        <div class="cta-buttons">
          <a class="btn btn-primary" href="https://discord.com/oauth2/authorize?client_id=<%= clientId %>&permissions=3147776&scope=bot%20applications.commands">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
            Add to Discord
          </a>
          <a href="#commands" class="btn btn-secondary">View Commands</a>
        </div>
      </div>
    </section>

    <section class="features" id="features">
      <div class="container">
        <div class="section-title">
          <h2>Why Sound Bot?</h2>
          <p>Everything you need for the perfect music experience</p>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon spotify">🎧</div>
            <h3>Spotify Integration</h3>
            <p>Play your favorite tracks, albums, and playlists directly from Spotify URLs.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon soundcloud">☁️</div>
            <h3>SoundCloud Support</h3>
            <p>Discover and play tracks from SoundCloud's vast library of independent artists.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon commands">⚡</div>
            <h3>Simple Commands</h3>
            <p>Easy-to-use slash commands that anyone in your server can use right away.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon quality">🔊</div>
            <h3>High Quality Audio</h3>
            <p>Crystal clear audio streaming with adjustable volume controls.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="commands-section" id="commands">
      <div class="container">
        <div class="section-title">
          <h2>Commands</h2>
          <p>All the controls you need at your fingertips</p>
        </div>
        <div class="commands-list">
          <div class="command">
            <span class="command-name">/music play</span>
            <span class="command-desc">Play a song or playlist</span>
          </div>
          <div class="command">
            <span class="command-name">/music pause</span>
            <span class="command-desc">Pause playback</span>
          </div>
          <div class="command">
            <span class="command-name">/music resume</span>
            <span class="command-desc">Resume playback</span>
          </div>
          <div class="command">
            <span class="command-name">/music skip</span>
            <span class="command-desc">Skip current song</span>
          </div>
          <div class="command">
            <span class="command-name">/music stop</span>
            <span class="command-desc">Stop and clear queue</span>
          </div>
          <div class="command">
            <span class="command-name">/music queue</span>
            <span class="command-desc">View the queue</span>
          </div>
          <div class="command">
            <span class="command-name">/music volume</span>
            <span class="command-desc">Adjust volume (1-100)</span>
          </div>
          <div class="command">
            <span class="command-name">/music shuffle</span>
            <span class="command-desc">Shuffle the queue</span>
          </div>
          <div class="command">
            <span class="command-name">/music nowplaying</span>
            <span class="command-desc">Show current track</span>
          </div>
          <div class="command">
            <span class="command-name">!play</span>
            <span class="command-desc">Legacy prefix command</span>
          </div>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <div class="cta-box">
          <h2>Ready to bring music to your server?</h2>
          <p>Add Sound Bot now and start playing your favorite tracks in seconds.</p>
          <a class="btn btn-primary" href="https://discord.com/oauth2/authorize?client_id=<%= clientId %>&permissions=3147776&scope=bot%20applications.commands">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
            Add to Discord
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>Made with ❤️ for Discord communities</p>
    </div>
  </footer>
</body>
</html>
